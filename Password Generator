import tkinter as tk
import random
import string

def generate_password():
    try:
        length = int(entry.get())
        if length < 4:
            result_label.config(text="Length must be at least 4")
            return

        chars = string.ascii_letters + string.digits + string.punctuation
        password = ''.join(random.choice(chars) for _ in range(length))
        result_label.config(text="Generated Password: " + password)

        # Save to file
        with open("passwords.txt", "a") as f:
            f.write("Generated: " + password + "\n")

        # Copy to clipboard
        root.clipboard_clear()
        root.clipboard_append(password)
        root.update()

    except ValueError:
        result_label.config(text="Please enter a valid number")

def save_custom_password():
    password = custom_entry.get()
    if password.strip() == "":
        custom_result.config(text="Please enter a password first")
        return

    # Save to file
    with open("passwords.txt", "a") as f:
        f.write("Custom: " + password + "\n")

    # Copy to clipboard
    root.clipboard_clear()
    root.clipboard_append(password)
    root.update()

    custom_result.config(text="Custom Password Saved & Copied!")

root = tk.Tk()
root.title("Password Generator")
root.geometry("500x400")
root.configure(bg="peachpuff")

# Input for length
tk.Label(root, text="Enter password length:", bg="peachpuff", font=("Arial", 12)).pack(pady=10)
entry = tk.Entry(root)
entry.pack(pady=5)

# Generate button
tk.Button(root, text="Generate Password", command=generate_password, bg="lightblue", font=("Arial", 12)).pack(pady=10)

# Result label
result_label = tk.Label(root, text="", bg="peachpuff", font=("Arial", 12))
result_label.pack(pady=10)

# Custom password section
tk.Label(root, text="Or create your own password:", bg="peachpuff", font=("Arial", 12)).pack(pady=10)
custom_entry = tk.Entry(root, width=30)
custom_entry.pack(pady=5)

tk.Button(root, text="Save Custom Password", command=save_custom_password, bg="lightgreen", font=("Arial", 12)).pack(pady=10)

custom_result = tk.Label(root, text="", bg="peachpuff", font=("Arial", 12))
custom_result.pack(pady=10)

root.mainloop()
